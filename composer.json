{
    "name": "mahdyfo/rotifer",
    "description": "A genetic AI framework that evolves its own neural network architecture through biologically-inspired neuroevolution (AutoML)",
    "license": "Apache-2.0",
    "keywords": [
        "AI",
        "genetic algorithm",
        "machine learning",
        "deep learning",
        "AutoML",
        "neural networks",
        "neuroevolution",
        "NEAT"
    ],
    "autoload": {
        "psr-4": {
            "Rotifer\\": "src/",
            "Rotifer\\Problems\\": "problems/"
        }
    },
    "authors": [
        {
            "name": "Mahdi Forghani Fard",
            "email": "mahdyfof@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "amphp/parallel": "^2.4"
    },
    "require-dev": {
        "psy/psysh": "^0.12.2",
        "phpunit/phpunit": "^10.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Rotifer\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/rotifer"
    ],
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "test:functional": "phpunit --testsuite Functional"
    }
}
